<Window x:Class="ClickerIn.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickerIn — Справка" Width="600" Height="550"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E" Foreground="#FFE0E0E0">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📖 Как пользоваться ClickerIn" FontSize="18" FontWeight="Bold"
                   Foreground="#FF8EA1E6" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <RichTextBox x:Name="RtbHelp" Background="Transparent" BorderThickness="0"
                         Foreground="#FFE0E0E0" IsReadOnly="True" FontSize="13">
                <RichTextBox.Document>
                    <FlowDocument/>
                </RichTextBox.Document>
            </RichTextBox>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Понятно!" Click="Close_Click" Width="120" Height="36"
                HorizontalAlignment="Center" Margin="0,15,0,0"
                Background="#FF8EA1E6" Foreground="#FF1E1E2E" FontWeight="Bold"
                BorderThickness="0" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>