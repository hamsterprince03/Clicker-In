<Application x:Class="ClickerIn.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E1E2E"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF2D2D44"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FF3E3E5E"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF2196F3"/>
        <SolidColorBrush x:Key="ActiveButtonBrush" Color="#FF8EA1E6"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#FF8EA1E6"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF3A3A5C"/>
        <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#FF4A4A6A"/>
        <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#FF1565C0"/>
        <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#FF161625"/>
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FF252540"/>
        <SolidColorBrush x:Key="GridAlternateBackgroundBrush" Color="#FF2A2A48"/>
        <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#FF3A3A5C"/>
        <SolidColorBrush x:Key="GridForegroundBrush" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="ToolBarBackgroundBrush" Color="#FF1E1E2E"/>
        <SolidColorBrush x:Key="TabBackgroundBrush" Color="#FF2D2D44"/>
        <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#FF3A3A5C"/>
        <sys:Double x:Key="GlobalFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
        <sys:Double x:Key="HeaderFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
        <sys:Double x:Key="SmallFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>
    </Application.Resources>
</Application>