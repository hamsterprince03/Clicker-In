<Window x:Class="ClickerIn.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickerIn Overlay" Width="300" Height="380"
        WindowStyle="None" AllowsTransparency="True"
        Icon="/pointinghand_100160.ico"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Border Background="#E61E1E2E" CornerRadius="12" Padding="14"
            BorderBrush="#FF3E3E5E" BorderThickness="1"
            MouseLeftButtonDown="OverlayDrag">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.6" ShadowDepth="4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="🖱 ClickerIn" FontSize="16" FontWeight="Bold"
                           Foreground="#FF8EA1E6" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🏠" Click="MainWindow_Click" Width="26" Height="26"
                            Background="Transparent" Foreground="#FFE0E0E0"
                            BorderThickness="0" Cursor="Hand" ToolTip="Главное окно"
                            Margin="0,0,4,0"/>
                    <Button Content="✕" Click="CloseOverlay_Click" Width="26" Height="26"
                            Background="Transparent" Foreground="#FF888888"
                            BorderThickness="0" Cursor="Hand" FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- Scenario selector -->
            <Border Grid.Row="1" Background="#FF2D2D44" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Сценарий:" Foreground="#FFE0E0E0" Margin="0,0,0,4"
                               FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbScenarios" Height="28"
                              Background="#FFEAEAEA" Foreground="#FF1A1A2E"
                              BorderBrush="#FF3E3E5E" FontWeight="Bold" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Run / Stop -->
            <Grid Grid.Row="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnOverlayRun" Grid.Column="0" Content="▶ Запуск"
                        Click="RunOverlay_Click" Height="32" Margin="0,0,4,0"
                        Background="#FF8EA1E6" Foreground="#FF1E1E2E" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnOverlayStop" Grid.Column="1" Content="⏹ Стоп"
                        Click="StopOverlay_Click" Height="32" IsEnabled="False"
                        Background="#FF3A3A5C" Foreground="#FFE0E0E0"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>

            <!-- Record / Stop record -->
            <Grid Grid.Row="3" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnOverlayRecord" Grid.Column="0" Content="⏺ Запись"
                        Click="RecordOverlay_Click" Height="30" Margin="0,0,4,0"
                        Background="#FF5C3A3A" Foreground="#FFFF8888"
                        BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnOverlayStopRec" Grid.Column="1" Content="⏹ Стоп запись"
                        Click="StopRecOverlay_Click" Height="30" IsEnabled="False"
                        Background="#FF3A3A5C" Foreground="#FFE0E0E0"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>

            <!-- Schedule button -->
            <Button Grid.Row="4" Content="⏰ Расписание" Click="ScheduleOverlay_Click"
                    Height="30" Margin="0,0,0,6"
                    Background="#FF3A3A5C" Foreground="#FFE0E0E0"
                    BorderThickness="0" Cursor="Hand"/>

            <!-- Status -->
            <Border Grid.Row="5" Background="#FF252540" CornerRadius="4" Padding="8,5"
                    Margin="0,0,0,6">
                <TextBlock x:Name="TxtOverlayStatus" Text="Готов" Foreground="LimeGreen"
                           FontSize="12" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </Border>

            <!-- Upcoming schedules -->
            <Border Grid.Row="6" Background="#FF252540" CornerRadius="6" Padding="6">
                <StackPanel>
                    <TextBlock Text="📅 Ближайшие:" Foreground="#FF888888"
                               FontSize="10" Margin="0,0,0,4"/>
                    <ListBox x:Name="LstUpcoming" Background="Transparent"
                             BorderThickness="0" Foreground="#FFCCCCCC" FontSize="10"
                             MaxHeight="80"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <TextBlock Grid.Row="7" Text="Ctrl+F8: старт/стоп | Ctrl+F9: запись"
                       Foreground="#FF555555" FontSize="9" HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </Grid>
    </Border>
</Window>