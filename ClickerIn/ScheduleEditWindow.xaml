<Window x:Class="ClickerIn.ScheduleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройка расписания" Width="580" Height="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
		
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontSize="{DynamicResource GlobalFontSize}">
	<Grid Margin="14">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Scenario / Chain toggle -->
		<Border Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
			<StackPanel>
				<TextBlock Text="📋 Что запускать:" FontWeight="Bold" Margin="0,0,0,8"/>

				<RadioButton x:Name="RbSingle" Content="Один сценарий" GroupName="What"
                             IsChecked="True" Margin="0,0,0,4"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Checked="WhatMode_Changed"/>
				<StackPanel x:Name="PanelSingleScenario" Orientation="Horizontal" Margin="20,0,0,6">
					<ComboBox x:Name="CmbScenario" Width="250" Height="28"
                              DisplayMemberPath="Name"
                              Background="{DynamicResource GridBackgroundBrush}"
                              Foreground="#FF1E1E2E" FontWeight="SemiBold"
                              BorderBrush="{DynamicResource BorderBrush}"/>
				</StackPanel>

				<RadioButton x:Name="RbChain" Content="Цепочка сценариев (друг за другом)" GroupName="What"
                             Margin="0,0,0,4"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Checked="WhatMode_Changed"/>
				<Border x:Name="PanelChain" Visibility="Collapsed"
                        Background="{DynamicResource GridBackgroundBrush}"
                        CornerRadius="4" Padding="8" Margin="20,0,0,6">
					<StackPanel>
						<StackPanel Orientation="Horizontal" Margin="0,0,0,6">
							<ComboBox x:Name="CmbChainAdd" Width="180" Height="26"
                                      DisplayMemberPath="Name"
                                      Background="{DynamicResource GridAlternateBackgroundBrush}"
                                      Foreground="#FF1E1E2E"
                                      BorderBrush="{DynamicResource BorderBrush}"/>
							<TextBlock Text="Пауза мс:" VerticalAlignment="Center" Margin="8,0,4,0" FontSize="11"/>
							<TextBox x:Name="TxtChainDelay" Width="50" Text="2000" Height="26"
                                     TextAlignment="Center"
                                     Background="{DynamicResource GridAlternateBackgroundBrush}"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"/>
							<Button Content="➕" Click="AddChainItem_Click" Width="28" Height="26"
                                    Margin="4,0,0,0"
                                    Background="{DynamicResource ButtonBackgroundBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}"
                                    BorderThickness="0" Cursor="Hand"/>
						</StackPanel>

						<ListBox x:Name="LstChain" MaxHeight="100" Background="Transparent"
                                 BorderThickness="0" Foreground="{DynamicResource ForegroundBrush}"
                                 FontSize="11" DisplayMemberPath="Display"/>

						<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
							<Button Content="⬆" Click="ChainUp_Click" Width="26" Height="24"
                                    Background="{DynamicResource ButtonBackgroundBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}"
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,2,0"/>
							<Button Content="⬇" Click="ChainDown_Click" Width="26" Height="24"
                                    Background="{DynamicResource ButtonBackgroundBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}"
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,2,0"/>
							<Button Content="🗑" Click="ChainRemove_Click" Width="26" Height="24"
                                    Background="{DynamicResource ButtonBackgroundBrush}"
                                    Foreground="{DynamicResource ButtonForegroundBrush}"
                                    BorderThickness="0" Cursor="Hand"/>
							<CheckBox x:Name="ChkStopOnError" Content="Стоп при ошибке"
                                      IsChecked="True" Margin="12,0,0,0"
                                      Foreground="{DynamicResource ForegroundBrush}"
                                      VerticalAlignment="Center" FontSize="11"/>
						</StackPanel>
					</StackPanel>
				</Border>
			</StackPanel>
		</Border>

		<!-- Schedule mode -->
		<Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
			<StackPanel>
				<TextBlock Text="⏰ Когда запускать:" FontWeight="Bold" Margin="0,0,0,8"/>
				<WrapPanel>
					<RadioButton x:Name="RbOnce" Content="Однократно" GroupName="Mode"
                                 IsChecked="True" Margin="0,0,14,4"
                                 Foreground="{DynamicResource ForegroundBrush}" Checked="Mode_Changed"/>
					<RadioButton x:Name="RbDaily" Content="Ежедневно" GroupName="Mode"
                                 Margin="0,0,14,4"
                                 Foreground="{DynamicResource ForegroundBrush}" Checked="Mode_Changed"/>
					<RadioButton x:Name="RbWeekly" Content="По дням" GroupName="Mode"
                                 Margin="0,0,14,4"
                                 Foreground="{DynamicResource ForegroundBrush}" Checked="Mode_Changed"/>
					<RadioButton x:Name="RbInterval" Content="С интервалом" GroupName="Mode"
                                 Foreground="{DynamicResource ForegroundBrush}" Checked="Mode_Changed"/>
				</WrapPanel>
			</StackPanel>
		</Border>

		<!-- Time settings -->
		<Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
			<StackPanel>
				<!-- Once -->
				<StackPanel x:Name="PanelOnce">
					<TextBlock Text="📅 Дата и время:" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<StackPanel Orientation="Horizontal">
						<DatePicker x:Name="DpDate" Width="160"
                                    Background="{DynamicResource GridBackgroundBrush}" Margin="0,0,8,0"/>
						<TextBox x:Name="TxtOnceHour" Width="40" Text="12" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
						<TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
						<TextBox x:Name="TxtOnceMinute" Width="40" Text="00" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
					</StackPanel>
				</StackPanel>

				<!-- Daily -->
				<StackPanel x:Name="PanelDaily" Visibility="Collapsed">
					<TextBlock Text="🕐 Время:" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<StackPanel Orientation="Horizontal">
						<TextBox x:Name="TxtDailyHour" Width="40" Text="14" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
						<TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
						<TextBox x:Name="TxtDailyMinute" Width="40" Text="00" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
					</StackPanel>
				</StackPanel>

				<!-- Weekly -->
				<StackPanel x:Name="PanelWeekly" Visibility="Collapsed">
					<TextBlock Text="📅 По дням:" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<ItemsControl x:Name="WeekDaysList">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Margin="0,1" Padding="4,3"
                                        Background="{DynamicResource GridBackgroundBrush}" CornerRadius="3">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="28"/>
											<ColumnDefinition Width="95"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="38"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="38"/>
										</Grid.ColumnDefinitions>
										<CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" Text="{Binding DayName}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ForegroundBrush}" FontSize="12"/>
										<TextBlock Grid.Column="2" Text="в" VerticalAlignment="Center" Margin="4,0"/>
										<TextBox Grid.Column="3" Text="{Binding Hour, UpdateSourceTrigger=PropertyChanged}"
                                                 TextAlignment="Center" FontSize="12"
                                                 Background="{DynamicResource GridAlternateBackgroundBrush}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}"/>
										<TextBlock Grid.Column="4" Text=":" VerticalAlignment="Center" Margin="1,0"/>
										<TextBox Grid.Column="5" Text="{Binding Minute, UpdateSourceTrigger=PropertyChanged}"
                                                 TextAlignment="Center" FontSize="12"
                                                 Background="{DynamicResource GridAlternateBackgroundBrush}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>

				<!-- Interval -->
				<StackPanel x:Name="PanelInterval" Visibility="Collapsed">
					<TextBlock Text="🔄 Интервал:" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<StackPanel Orientation="Horizontal" Margin="0,0,0,6">
						<TextBlock Text="Каждые" VerticalAlignment="Center" Margin="0,0,4,0"/>
						<TextBox x:Name="TxtIntervalMinutes" Width="50" Text="30" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
						<TextBlock Text="минут" VerticalAlignment="Center" Margin="4,0"/>
					</StackPanel>
					<CheckBox x:Name="ChkTodayOnly" Content="Только сегодня" IsChecked="True"
                              Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="С" VerticalAlignment="Center" Margin="0,0,4,0"/>
						<TextBox x:Name="TxtStartHour" Width="38" Text="09" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
						<TextBlock Text=":" VerticalAlignment="Center" Margin="1,0"/>
						<TextBox x:Name="TxtStartMinute" Width="38" Text="00" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
						<TextBlock Text="до" VerticalAlignment="Center" Margin="8,0,4,0"/>
						<TextBox x:Name="TxtEndHour" Width="38" Text="18" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
						<TextBlock Text=":" VerticalAlignment="Center" Margin="1,0"/>
						<TextBox x:Name="TxtEndMinute" Width="38" Text="00" TextAlignment="Center"
                                 Background="{DynamicResource GridBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
					</StackPanel>
				</StackPanel>
			</StackPanel>
		</Border>

		<!-- Additional -->
		<Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}"
                CornerRadius="6" Padding="12" Margin="0,0,0,10">
			<StackPanel>
				<TextBlock Text="⚙ Дополнительно:" FontWeight="SemiBold" Margin="0,0,0,6"/>
				<StackPanel Orientation="Horizontal" Margin="0,0,0,6">
					<TextBlock Text="Процесс:" VerticalAlignment="Center" Margin="0,0,4,0"/>
					<TextBox x:Name="TxtProcess" Width="180"
                             Background="{DynamicResource GridBackgroundBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" Padding="4,2"/>
				</StackPanel>
				<CheckBox x:Name="ChkPreAlert" Content="Предупреждать заранее" IsChecked="True"
                          Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
				<StackPanel Orientation="Horizontal" Margin="20,0,0,0">
					<TextBlock Text="За" VerticalAlignment="Center" Margin="0,0,4,0"/>
					<TextBox x:Name="TxtPreAlertMin" Width="40" Text="5" TextAlignment="Center"
                             Background="{DynamicResource GridBackgroundBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
					<TextBlock Text="мин до запуска" VerticalAlignment="Center" Margin="4,0"/>
				</StackPanel>
			</StackPanel>
		</Border>

		<!-- Preview -->
		<Border Grid.Row="4" Background="{DynamicResource GridBackgroundBrush}"
                CornerRadius="6" Padding="10" Margin="0,0,0,10">
			<StackPanel>
				<TextBlock Text="👁 Предпросмотр:" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="11"/>
				<TextBlock x:Name="TxtPreview" Foreground="#FF8EA1E6" TextWrapping="Wrap" FontSize="12"/>
			</StackPanel>
		</Border>

		<!-- Buttons -->
		<StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Content="✅ Сохранить" Click="Save_Click" Padding="16,6" Margin="0,0,8,0"
                    Background="#FF8EA1E6" Foreground="#FF1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"/>
			<Button Content="Отмена" Click="Cancel_Click" Padding="16,6"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"
                    BorderThickness="0" Cursor="Hand"/>
		</StackPanel>
	</Grid>
</Window>