<Window x:Class="ClickerIn.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight" MaxWidth="420"
        WindowStartupLocation="Manual">
	<Border x:Name="MainBorder" CornerRadius="10" Padding="16,14" Margin="8"
            Background="#FF2D2D44" BorderBrush="#FF3E3E5E" BorderThickness="1">
		<Border.Effect>
			<DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.6" ShadowDepth="4"/>
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Header -->
			<Grid Grid.Row="0" Margin="0,0,0,6">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock x:Name="TxtIcon" Grid.Column="0" Text="ℹ"
                           FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
				<TextBlock x:Name="TxtTitle" Grid.Column="1"
                           FontWeight="Bold" Foreground="#FFE0E0E0" FontSize="14"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
				<Button Grid.Column="2" Content="✕" Click="Close_Click"
                        Background="Transparent" Foreground="#FF888888" BorderThickness="0"
                        FontSize="12" Cursor="Hand" Width="22" Height="22"
                        VerticalAlignment="Top"/>
			</Grid>

			<!-- Message -->
			<TextBlock x:Name="TxtMessage" Grid.Row="1"
                       Foreground="#FFCCCCCC" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

			<!-- Countdown -->
			<TextBlock x:Name="TxtCountdown" Grid.Row="2"
                       Foreground="#FF8EA1E6" FontSize="11"
                       Margin="0,0,0,10" Visibility="Collapsed"/>

			<!-- Action buttons -->
			<StackPanel x:Name="PanelActions" Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
				<Button x:Name="BtnPostpone" Content="⏰ Отложить на 5 мин"
                        Click="Postpone_Click" Padding="12,6" Margin="0,0,8,0"
                        Background="#FF3A3A5C" Foreground="#FFE0E0E0"
                        BorderThickness="0" Cursor="Hand" FontSize="12"/>
				<Button x:Name="BtnAccept" Content="✅ Согласен"
                        Click="Accept_Click" Padding="12,6"
                        Background="#FF8EA1E6" Foreground="#FF1E1E2E"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" FontSize="12"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>